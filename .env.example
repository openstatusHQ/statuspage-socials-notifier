# Inbound auth — set the same value as a custom header on the openstatus
# webhook subscriber:  Authorization: Bearer <this>
OPENSTATUS_WEBHOOK_TOKEN=

# Port to listen on (default: 3000)
PORT=3000

# Optional behavior
# Comma-separated statuses to post on (default: all). e.g. investigating,resolved
POST_ON_STATUSES=
# Post scheduled-maintenance events (default: true)
POST_MAINTENANCE=true

# --- Bluesky (use an App Password, not your login password) ---
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# BLUESKY_SERVICE=https://bsky.social

# --- X / Twitter (OAuth 1.0a user context — app must have Read+Write) ---
# From the X developer portal: consumer keys + the posting account's access token.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
